# SWARM ORCHESTRATOR — Environment Configuration
# ════════════════════════════════════════════════════════════════

# Service
PORT=3040
NODE_ENV=development

# Database (sovereign PostgreSQL)
DATABASE_URL=postgresql://user:pass@localhost:5432/swarm_orchestrator

# Loom — the temple's inference engine (where Gemma E2B/E4B live)
LOOM_URL=http://localhost:3038

# Governance — for Qwen3-235B synthesis via Together AI gateway
GOVERNANCE_URL=http://localhost:3010
# In production: GOVERNANCE_URL=https://governance-production-f1bb.up.railway.app

# Zakhor — for stigmergic trace recording
ZAKHOR_URL=http://localhost:3025

# NESHAMAH — for nervous system signals (presence witness, sabbath)
